  "query": "\n        INSERT INTO players (bbref_id, name)\n        VALUES ($1, $2)\n        ON CONFLICT (bbref_id) DO UPDATE SET\n            name = EXCLUDED.name,\n            updated_at = NOW()\n        RETURNING id, bbref_id, name, created_at, updated_at\n        ",
