      "targets": [
        {
          "datasource": "Sports PostgreSQL",
          "format": "table",
          "rawSql": "SELECT p.name, t.code AS team, SUM(bl.h) AS hits, SUM(bl.ab) AS ab, SUM(bl.r) AS runs, SUM(bl.rbi) AS rbi, ROUND(SUM(bl.h)::numeric / NULLIF(SUM(bl.ab), 0)::numeric, 3) AS avg FROM batting_lines bl JOIN players p ON bl.player_id = p.id JOIN teams t ON bl.team_id = t.id JOIN games g ON bl.game_id = g.id WHERE ($season = '' OR EXTRACT(YEAR FROM g.game_date) = $season::int) AND bl.ab IS NOT NULL AND bl.batting_order IS NOT NULL GROUP BY p.name, t.code HAVING SUM(bl.ab) >= 200 ORDER BY hits DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top 10 Batters by Hits",
      "type": "table"
