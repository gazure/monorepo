          "rawSql": "SELECT p.name, t.code AS team, ROUND(SUM(pl.er)::numeric * 9.0 / NULLIF(SUM(pl.ip), 0)::numeric, 2) AS era, ROUND(SUM(pl.ip)::numeric, 1) AS ip, SUM(pl.so) AS strikeouts, SUM(pl.bb) AS walks, ROUND((SUM(pl.h) + SUM(pl.bb))::numeric / NULLIF(SUM(pl.ip), 0)::numeric, 2) AS whip FROM pitching_lines pl JOIN players p ON pl.player_id = p.id JOIN teams t ON pl.team_id = t.id JOIN games g ON pl.game_id = g.id WHERE ($season = '' OR EXTRACT(YEAR FROM g.game_date) = $season::int) GROUP BY p.name, t.code HAVING SUM(pl.ip) >= 100 ORDER BY era ASC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top 10 Pitchers by ERA (min 100 IP)",
      "type": "table"
